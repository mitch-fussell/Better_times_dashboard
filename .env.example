# Copy the values you need into Vercel's Environment Variables (Project → Settings
# → Environment Variables). The two NEXT_PUBLIC_ Supabase vars already exist.

# --- Existing (already set) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Digest job: reading data with no logged-in user ---
# Supabase → Project Settings → API → "service_role" secret. SERVER-ONLY, never
# expose to the browser. Bypasses RLS so the cron can read all clients/check-ins.
SUPABASE_SERVICE_ROLE_KEY=

# Protects /api/digest so only Vercel Cron (and you, with ?secret=) can trigger it.
# Any long random string. Vercel Cron sends it automatically as a Bearer token.
CRON_SECRET=

# --- Email (Resend) ---
# resend.com → API Keys. In test mode you can only send to your Resend account
# email, and must send FROM onboarding@resend.dev (the default below).
RESEND_API_KEY=
DIGEST_EMAIL_TO=              # comma-separated; in test mode = your Resend account email
DIGEST_EMAIL_FROM=BetterTimes <onboarding@resend.dev>

# --- Slack ---
# Slack → create an app → Incoming Webhooks → Add New Webhook to Workspace, pick
# a channel, copy the https://hooks.slack.com/services/... URL here.
SLACK_WEBHOOK_URL=

# --- Optional: link in the digest ---
# Your production URL. If unset, falls back to Vercel's production domain.
NEXT_PUBLIC_APP_URL=
